// Minimal test case for type mixing bug between real and int
partition simple_part(int x) = x;

table TestTable {
    primary int id;
    node simple_part(id);
    float price;      // real type
    int quantity;     // int type  
    float amount;     // real type
}

void test_type_mixing(int table_id, float item_price, int qty) {
    hop {
        // This should cause "invalid argument types (real and int) to binary operator *"
        TestTable[id: table_id].amount = item_price * qty;
        
        // This should cause "invalid argument types (real and int) to binary operator +"
        TestTable[id: table_id].price = TestTable[id: table_id].price + qty;
    }
}
