// Bug #2: Missing modifies clauses  
// This test reproduces the "command assigns to a global variable not in enclosing procedure's modifies clause" error
// The bug occurs when verification procedures have incomplete modifies clauses

partition node_selector(int x) = x;

table TestTable {
    primary int id;
    node node_selector(id);
    float balance;
}

table SecondTable {  
    primary int id;
    node node_selector(id);
    int count;
}

table ThirdTable {
    primary int id; 
    node node_selector(id);
    float amount;
}

void transaction_a(int test_id) {
    hop {
        TestTable[id: test_id].balance = TestTable[id: test_id].balance + 10.0;
        ThirdTable[id: test_id].amount = ThirdTable[id: test_id].amount + 5.0;
    }
}

void transaction_b(int test_id) {
    hop {
        SecondTable[id: test_id].count = SecondTable[id: test_id].count + 1;  
        ThirdTable[id: test_id].amount = ThirdTable[id: test_id].amount - 2.0;
    }
}
