// ============================================================================
// Partitions
// ============================================================================

partition f(x: int) -> int {
    return 10 * x;
}

partition g(x: int, y: int) -> int {
    return 10 * x + y;
}

// Implementation of partition is optional. It is 10 * x + (y % 10).
partition h(x: int, y: int) -> int {
    return 10 * x + (y % 10);
}

// ============================================================================
// Tables
// ============================================================================

table Warehouse {
    primary W_ID: int;
    node f(W_ID);

    W_NAME: string;
    W_STREET_1: string;
    W_STREET_2: string;
    W_CITY: string;
    W_STATE: string;
    W_ZIP: string;
    W_TAX: float;
    W_YTD: float;
}

// PK: D_W_ID, D_ID (2) → D_ID (1). Dropped: D_W_ID entirely from schema.
// Node: g(D_W_ID, D_ID) → g(1, D_ID)
table District {
    primary D_ID: int;
    node g(1, D_ID);

    D_NAME: string;
    D_STREET_1: string;
    D_STREET_2: string;
    D_CITY: string;
    D_STATE: string;
    D_ZIP: string;
    D_TAX: float;
    D_YTD: float;
    D_NEXT_O_ID: int;
    D_NEXT_NO_ID: int;
}

// PK: C_W_ID, C_D_ID, C_ID (3) → C_ID (1). Dropped: C_W_ID, C_D_ID.
// Node: g(C_W_ID, C_D_ID) → g(1, C_ID)
table Customer {
    primary C_ID: int;
    node g(1, C_ID);

    C_FIRST: string;
    C_MIDDLE: string;
    C_LAST: string;
    C_STREET_1: string;
    C_STREET_2: string;
    C_CITY: string;
    C_STATE: string;
    C_ZIP: string;
    C_PHONE: string;
    C_SINCE: int;
    C_CREDIT: string;
    C_CREDIT_LIMIT: float;
    C_DISCOUNT: float;
    C_BALANCE: float;
    C_YTD_PAYMENT: float;
    C_PAYMENT_CNT: float;
    C_DELIVERY_CNT: float;
    C_DATA: string;
}

// Never used in here, but included for completeness
// table History {
//     H_C_W_ID: int;
//     H_C_D_ID: int;
//     H_C_ID: int;
//     H_D_ID: int;
//     H_W_ID: int;
//     H_DATE: int;
//     H_AMOUNT: int;
//     H_DATA: int;
// }

// PK: NO_W_ID, NO_D_ID, NO_O_ID (3) → NO_O_ID (1). Dropped: NO_W_ID, NO_D_ID.
// Node: g(NO_W_ID, NO_D_ID) → g(1, NO_O_ID)
table New_Order {
    primary NO_O_ID: int;
    node g(1, NO_O_ID);
}

// PK: O_W_ID, O_D_ID, O_ID (3) → O_ID (1). Dropped: O_W_ID, O_D_ID.
// Node: g(O_W_ID, O_D_ID) → g(1, O_ID)
table Order {
    primary O_ID: int;
    node g(1, O_ID);

    O_C_ID: int;
    O_ENTRY_DATE: int;
    O_CARRIER_ID: int;
    O_OL_CNT: int;
    O_ALL_LOCAL: int;
}

// PK: OL_W_ID, OL_D_ID, OL_O_ID, OL_NUMBER (4) → OL_NUMBER (1). Dropped: OL_W_ID, OL_D_ID, OL_O_ID.
// Node: g(OL_W_ID, OL_D_ID) → g(1, OL_NUMBER)
table Order_Line {
    primary OL_NUMBER: int;
    node g(1, OL_NUMBER);

    OL_I_ID: int;
    OL_SUPPLY_W_ID: int;
    OL_DELIVERY_DATE: int;
    OL_QUANTITY: int;
    OL_AMOUNT: int;
    OL_DIST_INTO: string;
}

// PK: I_ID, W_ID (2) → I_ID (1). Dropped: W_ID.
// Node: h(W_ID, I_ID) → h(0, I_ID)
table Item {
    primary I_ID: int;
    node h(0, I_ID);

    I_IM_ID: int;
    I_NAME: string;
    I_PRICE: float;
    I_DATA: string;
}

// PK: S_W_ID, S_I_ID (2) → S_I_ID (1). Dropped: S_W_ID.
// Node: h(S_W_ID, S_I_ID) → h(0, S_I_ID)
table Stock {
    primary S_I_ID: int;
    node h(0, S_I_ID);

    S_QUANTITY: int;
    S_YTD: float;
    S_ORDER_CNT: int;
    S_REMOTE_CNT: int;
    S_DATA: string;

    // invariant S_QUANTITY >= 0 && S_QUANTITY <= 100;
}

// ============================================================================
// Constants and Helper Declarations
// ============================================================================

const O_OL_CNT: int = 10;

// ============================================================================
// Transactions
// ============================================================================

// New-Order
transaction newOrder(
    w_id: int,
    d_id: int,
    c_id: int,
    o_all_local: int,
    date: int,
    itemIDs: List<int>,
    supplierWarehouseIDs: List<int>,
    orderQuantities: List<int>
) -> float
    assume length(itemIDs) == O_OL_CNT;
    assume length(supplierWarehouseIDs) == O_OL_CNT;
    assume length(orderQuantities) == O_OL_CNT;
    assume orderQuantities.get(0) >= 0 && orderQuantities.get(0) <= 10;
    assume orderQuantities.get(1) >= 0 && orderQuantities.get(1) <= 10;
    assume orderQuantities.get(2) >= 0 && orderQuantities.get(2) <= 10;
    assume orderQuantities.get(3) >= 0 && orderQuantities.get(3) <= 10;
    assume orderQuantities.get(4) >= 0 && orderQuantities.get(4) <= 10;
    assume orderQuantities.get(5) >= 0 && orderQuantities.get(5) <= 10;
    assume orderQuantities.get(6) >= 0 && orderQuantities.get(6) <= 10;
    assume orderQuantities.get(7) >= 0 && orderQuantities.get(7) <= 10;
    assume orderQuantities.get(8) >= 0 && orderQuantities.get(8) <= 10;
    assume orderQuantities.get(9) >= 0 && orderQuantities.get(9) <= 10;
{
    // Get warehouse tax (and any other per-warehouse data)
    hop {
        var w_tax: float = Warehouse[W_ID: w_id].W_TAX; // TODO: why read w_tax?
        // keep this table access for partitioning
        // Note: retained for parity with original; not used later in this snippet.
        var prices: List<float> = emptyList();
    }

    // Read item and update stock across partitions
    hops for ol_number: int = 0 to O_OL_CNT {
        var i_id: int = itemIDs.get(ol_number);
        var sup_w_id: int = supplierWarehouseIDs.get(ol_number);
        var qty: int = orderQuantities.get(ol_number);
        assert qty >= 0 && qty <= 10;

        // Read and update stock
        var s: Row<Stock> = Stock[S_I_ID: i_id];
        var price: float = Item[I_ID: i_id].I_PRICE;
        prices = append(prices, price);

        if s.S_QUANTITY - qty >= 10 {
            s.S_QUANTITY = s.S_QUANTITY - qty;
        } else {
            s.S_QUANTITY = s.S_QUANTITY + 91 - qty;
        }

        // assert s.S_QUANTITY >= 0;

        if sup_w_id != w_id {
            s.S_REMOTE_CNT = s.S_REMOTE_CNT + 1;
        }

        s.S_ORDER_CNT = s.S_ORDER_CNT + 1;
        s.S_YTD = s.S_YTD + float(qty);
        Stock[S_I_ID: i_id] = s;
    }

    // Update district, create order and order lines
    hop {
        // Read district and increment next order id (1 PK lookup)
        var d_next_oid: int = District[D_ID: d_id].D_NEXT_O_ID;
        var d_tax: float = District[D_ID: d_id].D_TAX;
        District[D_ID: d_id].D_NEXT_O_ID = d_next_oid + 1;

        // Insert Order (1 PK)
        Order[O_ID: d_next_oid] = {
            O_C_ID: c_id,
            O_ENTRY_DATE: date,
            O_OL_CNT: O_OL_CNT,
            O_ALL_LOCAL: o_all_local
        };

        // Insert NewOrder (1 PK)
        New_Order[NO_O_ID: d_next_oid] = {};

        // Insert order lines (1 PK)
        for (var ol_number: int = 0; ol_number < O_OL_CNT; ol_number = ol_number + 1) {
            var i_id: int = itemIDs.get(ol_number);
            var sup_w_id: int = supplierWarehouseIDs.get(ol_number);
            var qty: int = orderQuantities.get(ol_number);

            // Re-read item price here (instead of storing itemPrices from prior hops)
            // var price: float = Item[I_ID: i_id].I_PRICE;
            var price: float = prices.get(ol_number);

            Order_Line[OL_NUMBER: ol_number] = {
                OL_I_ID: i_id,
                OL_SUPPLY_W_ID: sup_w_id,
                OL_QUANTITY: qty,
                OL_AMOUNT: int(price * float(qty)) // TODO: rounding
            };
        }
        // to_unit(w_tax); // to avoid unused variable elimination
        return w_tax;
    }
}
