// Expectation: loop bound from function call result should not be unrolled.

function dyn_bound(x: int) -> int {
    return x;
}

function unknown_bound_call(n: int) -> int {
    var bound: int = dyn_bound(n);
    var sum: int = 0;
    for (var i: int = 0; i < bound; i = i + 1) {
        sum = sum + i;
    }
    return sum;
}
