partition f(int x);
partition g(int x) = x * 10;

table TestTable {
    primary int ID;
    node f(ID);
    int VALUE;
}

table AnotherTable {
    primary int ID;
    int V;

    node g(ID);
}

void test_function() {
    hop {
        TestTable[ID: 1].VALUE = 42;
    }

    hop {
        AnotherTable[ID: 2].V = 84;
    }
}

void another_function() {
    hop {
        int x = 1;
        TestTable[ID: x].VALUE = 23;
    }

    hop {
        x = 2;
        AnotherTable[ID: x * 2].V = 42;
    }
}
