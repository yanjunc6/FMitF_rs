function partition_func(x: int) -> int {
    return x % 10;
}

function another_partition(a: int, b: int) -> int {
    return a + b;
}

table TestTable {
    primary id: int;
    name: string;
    active: bool;
    score: int;
    node partition_func(id);
    node another_partition(id, score);
    invariant score > 0;
}

transaction test_transaction(table_id: int) {
    hop {
        var value: int = TestTable[id: table_id].score;
    }
}